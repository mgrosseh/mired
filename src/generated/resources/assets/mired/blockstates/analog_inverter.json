{
  "multipart": [
    {
      "apply": {
        "model": "mired:block/analog_inverter/block_on"
      },
      "when": {
        "facing": "north",
        "powered": "true"
      }
    },
    {
      "apply": {
        "model": "mired:block/analog_inverter/block_off"
      },
      "when": {
        "facing": "north",
        "powered": "false"
      }
    },
    {
      "apply": {
        "model": "mired:block/analog_inverter/block_on",
        "y": 180
      },
      "when": {
        "facing": "south",
        "powered": "true"
      }
    },
    {
      "apply": {
        "model": "mired:block/analog_inverter/block_off",
        "y": 180
      },
      "when": {
        "facing": "south",
        "powered": "false"
      }
    },
    {
      "apply": {
        "model": "mired:block/analog_inverter/block_on",
        "y": 270
      },
      "when": {
        "facing": "west",
        "powered": "true"
      }
    },
    {
      "apply": {
        "model": "mired:block/analog_inverter/block_off",
        "y": 270
      },
      "when": {
        "facing": "west",
        "powered": "false"
      }
    },
    {
      "apply": {
        "model": "mired:block/analog_inverter/block_on",
        "y": 90
      },
      "when": {
        "facing": "east",
        "powered": "true"
      }
    },
    {
      "apply": {
        "model": "mired:block/analog_inverter/block_off",
        "y": 90
      },
      "when": {
        "facing": "east",
        "powered": "false"
      }
    }
  ]
}